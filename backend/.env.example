# ═══════════════════════════════════════════════
# Artemis Backend — Environment Configuration
# ═══════════════════════════════════════════════

# Neon Postgres Connection
DATABASE_URL=postgresql+asyncpg://user:password@host/neondb?sslmode=require

# Auth
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:8081,exp://192.168.1.100:8081

# MCP Core
MCP_MODEL_ENDPOINT=http://localhost:11434/api/generate
MCP_MODEL_NAME=llama3

# Arduino / Hardware Bridge
HARDWARE_BRIDGE_URL=http://192.168.1.50
MQTT_BROKER_URL=mqtt://192.168.1.50:1883
