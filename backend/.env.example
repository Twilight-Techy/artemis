# ═══════════════════════════════════════════════
# Artemis Backend — Environment Configuration
# ═══════════════════════════════════════════════

# Neon Postgres Connection
DATABASE_URL=postgresql+asyncpg://user:password@host/neondb?ssl=require

# Auth
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:8081,exp://192.168.1.100:8081

# Gemini API (MCP Core)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Notifications
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send

# ESP32 Hardware Bridge
# For a deployed backend, this must be reachable from the backend over the internet
# (for example a Cloudflare Tunnel, VPN overlay URL, or another authenticated HTTPS proxy).
# Do not use http://artemis-hub.local for cloud deployments; that only works on the same LAN.
ESP32_BASE_URL=https://your-esp32-public-url.example.com
ESP32_AUTH_TOKEN=your-shared-esp32-token
