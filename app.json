{
  "expo": {
    "name": "artemis",
    "slug": "artemis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0e10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.artemis.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Artemis needs microphone access to process your voice commands."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.artemis.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-audio",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#74b1ff",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "624919c5-83cd-45e7-ba7a-e1cc7d0932e4"
      }
    },
    "owner": "twilight-techie"
  }
}
